# Nested git repos — excluded because each contains its own .git/ directory.
# Git cannot track nested repos as regular directories (would become broken submodules).
# Clone instructions and local patch descriptions are in handoff.md and REPRODUCE_LOG.md.
SI2E/
base-rl-starter-files/
base-torch-ac/
base-drqv2/
base-vcse/
minigrid-pinned/

# Paper PDFs (large binaries — download separately)
*.pdf

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Hydra runtime outputs
**/exp/
**/exp_fixed/
**/.hydra/

# Training artifacts — large binary / replay data
**/buffer/
**/eval_video/
**/tb/
**/*.mp4
**/*.gif
**/*.png

# Model snapshots (large)
**/snapshot.pt
**/*.pt
**/*.pth

# Logs we don't need tracked (train.csv is large; keep eval.csv + train.log)
**/train.csv

# Editor / OS
.DS_Store
*.swp
*.swo
.vscode/
.idea/
